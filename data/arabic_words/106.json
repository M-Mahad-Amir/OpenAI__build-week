{"1":[{"position":1,"arabic":"لِإِيلَـٰفِ","translation":"For (the) familiarity"},{"position":2,"arabic":"قُرَيْشٍ","translation":"(of the) Quraish"}],"2":[{"position":1,"arabic":"إِۦلَـٰفِهِمْ","translation":"Their familiarity"},{"position":2,"arabic":"رِحْلَةَ","translation":"(with the) journey"},{"position":3,"arabic":"ٱلشِّتَآءِ","translation":"(of) winter"},{"position":4,"arabic":"وَٱلصَّيْفِ","translation":"and summer"}],"3":[{"position":1,"arabic":"فَلْيَعْبُدُوا۟","translation":"So let them worship"},{"position":2,"arabic":"رَبَّ","translation":"(the) Lord"},{"position":3,"arabic":"هَـٰذَا","translation":"(of) this"},{"position":4,"arabic":"ٱلْبَيْتِ","translation":"House"}],"4":[{"position":1,"arabic":"ٱلَّذِىٓ","translation":"The One Who"},{"position":2,"arabic":"أَطْعَمَهُم","translation":"feeds them"},{"position":3,"arabic":"مِّن","translation":"[from]"},{"position":4,"arabic":"جُوعٍۢ","translation":"(against) hunger"},{"position":5,"arabic":"وَءَامَنَهُم","translation":"and gives them security"},{"position":6,"arabic":"مِّنْ","translation":"from"},{"position":7,"arabic":"خَوْفٍۭ","translation":"fear"}]}