{"1":[{"position":1,"arabic":"إِنَّآ","translation":"Indeed, We"},{"position":2,"arabic":"أَعْطَيْنَـٰكَ","translation":"We have given you"},{"position":3,"arabic":"ٱلْكَوْثَرَ","translation":"Al-Kauthar"}],"2":[{"position":1,"arabic":"فَصَلِّ","translation":"So pray"},{"position":2,"arabic":"لِرَبِّكَ","translation":"to your Lord"},{"position":3,"arabic":"وَٱنْحَرْ","translation":"and sacrifice"}],"3":[{"position":1,"arabic":"إِنَّ","translation":"Indeed"},{"position":2,"arabic":"شَانِئَكَ","translation":"your enemy "},{"position":3,"arabic":"هُوَ","translation":"he (is)"},{"position":4,"arabic":"ٱلْأَبْتَرُ","translation":"the one cut off"}]}