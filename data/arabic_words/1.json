{"1":[{"position":1,"arabic":"بِسْمِ","translation":"In (the) name"},{"position":2,"arabic":"ٱللَّهِ","translation":"(of) Allah"},{"position":3,"arabic":"ٱلرَّحْمَـٰنِ","translation":"the Most Gracious"},{"position":4,"arabic":"ٱلرَّحِيمِ","translation":"the Most Merciful"}],"2":[{"position":1,"arabic":"ٱلْحَمْدُ","translation":"All praises and thanks"},{"position":2,"arabic":"لِلَّهِ","translation":"(be) to Allah"},{"position":3,"arabic":"رَبِّ","translation":"the Lord"},{"position":4,"arabic":"ٱلْعَـٰلَمِينَ","translation":"of the universe"}],"3":[{"position":1,"arabic":"ٱلرَّحْمَـٰنِ","translation":"The Most Gracious"},{"position":2,"arabic":"ٱلرَّحِيمِ","translation":"the Most Merciful"}],"4":[{"position":1,"arabic":"مَـٰلِكِ","translation":"(The) Master"},{"position":2,"arabic":"يَوْمِ","translation":"(of the) Day"},{"position":3,"arabic":"ٱلدِّينِ","translation":"(of the) Judgment"}],"5":[{"position":1,"arabic":"إِيَّاكَ","translation":"You Alone"},{"position":2,"arabic":"نَعْبُدُ","translation":"we worship"},{"position":3,"arabic":"وَإِيَّاكَ","translation":"and You Alone"},{"position":4,"arabic":"نَسْتَعِينُ","translation":"we ask for help"}],"6":[{"position":1,"arabic":"ٱهْدِنَا","translation":"Guide us"},{"position":2,"arabic":"ٱلصِّرَٰطَ","translation":"(to) the path"},{"position":3,"arabic":"ٱلْمُسْتَقِيمَ","translation":"the straight"}],"7":[{"position":1,"arabic":"صِرَٰطَ","translation":"(The) path"},{"position":2,"arabic":"ٱلَّذِينَ","translation":"(of) those"},{"position":3,"arabic":"أَنْعَمْتَ","translation":"You have bestowed (Your) Favors"},{"position":4,"arabic":"عَلَيْهِمْ","translation":"on them"},{"position":5,"arabic":"غَيْرِ","translation":"not (of)"},{"position":6,"arabic":"ٱلْمَغْضُوبِ","translation":"those who earned (Your) wrath"},{"position":7,"arabic":"عَلَيْهِمْ","translation":"on themselves"},{"position":8,"arabic":"وَلَا","translation":"and not"},{"position":9,"arabic":"ٱلضَّآلِّينَ","translation":"(of) those who go astray"}]}