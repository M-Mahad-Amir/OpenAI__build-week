{"1":[{"position":1,"arabic":"قُلْ","translation":"Say"},{"position":2,"arabic":"أَعُوذُ","translation":"I seek refuge"},{"position":3,"arabic":"بِرَبِّ","translation":"in (the) Lord"},{"position":4,"arabic":"ٱلْفَلَقِ","translation":"(of) the dawn"}],"2":[{"position":1,"arabic":"مِن","translation":"From"},{"position":2,"arabic":"شَرِّ","translation":"(the) evil"},{"position":3,"arabic":"مَا","translation":"(of) what"},{"position":4,"arabic":"خَلَقَ","translation":"He created"}],"3":[{"position":1,"arabic":"وَمِن","translation":"And from"},{"position":2,"arabic":"شَرِّ","translation":"(the) evil"},{"position":3,"arabic":"غَاسِقٍ","translation":"(of) darkness"},{"position":4,"arabic":"إِذَا","translation":"when"},{"position":5,"arabic":"وَقَبَ","translation":"it spreads"}],"4":[{"position":1,"arabic":"وَمِن","translation":"And from"},{"position":2,"arabic":"شَرِّ","translation":"(the) evil"},{"position":3,"arabic":"ٱلنَّفَّـٰثَـٰتِ","translation":"(of) the blowers"},{"position":4,"arabic":"فِى","translation":"in"},{"position":5,"arabic":"ٱلْعُقَدِ","translation":"the knots"}],"5":[{"position":1,"arabic":"وَمِن","translation":"And from"},{"position":2,"arabic":"شَرِّ","translation":"(the) evil"},{"position":3,"arabic":"حَاسِدٍ","translation":"(of) an envier"},{"position":4,"arabic":"إِذَا","translation":"when"},{"position":5,"arabic":"حَسَدَ","translation":"he envies"}]}