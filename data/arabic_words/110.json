{"1":[{"position":1,"arabic":"إِذَا","translation":"When"},{"position":2,"arabic":"جَآءَ","translation":"comes"},{"position":3,"arabic":"نَصْرُ","translation":"(the) Help"},{"position":4,"arabic":"ٱللَّهِ","translation":"(of) Allah"},{"position":5,"arabic":"وَٱلْفَتْحُ","translation":"and the Victory"}],"2":[{"position":1,"arabic":"وَرَأَيْتَ","translation":"And you see"},{"position":2,"arabic":"ٱلنَّاسَ","translation":"the people"},{"position":3,"arabic":"يَدْخُلُونَ","translation":"entering"},{"position":4,"arabic":"فِى","translation":"into"},{"position":5,"arabic":"دِينِ","translation":"(the) religion"},{"position":6,"arabic":"ٱللَّهِ","translation":"(of) Allah"},{"position":7,"arabic":"أَفْوَاجًۭا","translation":"(in) multitudes"}],"3":[{"position":1,"arabic":"فَسَبِّحْ","translation":"Then glorify"},{"position":2,"arabic":"بِحَمْدِ","translation":"with (the) praises"},{"position":3,"arabic":"رَبِّكَ","translation":"(of) your Lord"},{"position":4,"arabic":"وَٱسْتَغْفِرْهُ ۚ","translation":"and ask His forgiveness"},{"position":5,"arabic":"إِنَّهُۥ","translation":"Indeed, He"},{"position":6,"arabic":"كَانَ","translation":"is"},{"position":7,"arabic":"تَوَّابًۢا","translation":"Oft-Returning"}]}