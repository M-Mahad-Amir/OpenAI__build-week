{"1":[{"position":1,"arabic":"وَٱلشَّمْسِ","translation":"By the sun"},{"position":2,"arabic":"وَضُحَىٰهَا","translation":"and its brightness"}],"2":[{"position":1,"arabic":"وَٱلْقَمَرِ","translation":"And the moon"},{"position":2,"arabic":"إِذَا","translation":"when"},{"position":3,"arabic":"تَلَىٰهَا","translation":"it follows it"}],"3":[{"position":1,"arabic":"وَٱلنَّهَارِ","translation":"And the day"},{"position":2,"arabic":"إِذَا","translation":"when"},{"position":3,"arabic":"جَلَّىٰهَا","translation":"it displays it"}],"4":[{"position":1,"arabic":"وَٱلَّيْلِ","translation":"And the night"},{"position":2,"arabic":"إِذَا","translation":"when"},{"position":3,"arabic":"يَغْشَىٰهَا","translation":"it covers it"}],"5":[{"position":1,"arabic":"وَٱلسَّمَآءِ","translation":"And the heaven"},{"position":2,"arabic":"وَمَا","translation":"and (He) Who"},{"position":3,"arabic":"بَنَىٰهَا","translation":"constructed it"}],"6":[{"position":1,"arabic":"وَٱلْأَرْضِ","translation":"And the earth"},{"position":2,"arabic":"وَمَا","translation":"and by (He) Who"},{"position":3,"arabic":"طَحَىٰهَا","translation":"spread it"}],"7":[{"position":1,"arabic":"وَنَفْسٍۢ","translation":"And (the) soul"},{"position":2,"arabic":"وَمَا","translation":"and (He) Who"},{"position":3,"arabic":"سَوَّىٰهَا","translation":"proportioned it"}],"8":[{"position":1,"arabic":"فَأَلْهَمَهَا","translation":"And He inspired it"},{"position":2,"arabic":"فُجُورَهَا","translation":"(to distinguish) its wickedness"},{"position":3,"arabic":"وَتَقْوَىٰهَا","translation":"and its righteousness"}],"9":[{"position":1,"arabic":"قَدْ","translation":"Indeed"},{"position":2,"arabic":"أَفْلَحَ","translation":"he succeeds"},{"position":3,"arabic":"مَن","translation":"who"},{"position":4,"arabic":"زَكَّىٰهَا","translation":"purifies it"}],"10":[{"position":1,"arabic":"وَقَدْ","translation":"And indeed"},{"position":2,"arabic":"خَابَ","translation":"he fails"},{"position":3,"arabic":"مَن","translation":"who"},{"position":4,"arabic":"دَسَّىٰهَا","translation":"buries it"}],"11":[{"position":1,"arabic":"كَذَّبَتْ","translation":"Denied"},{"position":2,"arabic":"ثَمُودُ","translation":"Thamud"},{"position":3,"arabic":"بِطَغْوَىٰهَآ","translation":"by their transgression"}],"12":[{"position":1,"arabic":"إِذِ","translation":"When"},{"position":2,"arabic":"ٱنۢبَعَثَ","translation":"(was) sent forth"},{"position":3,"arabic":"أَشْقَىٰهَا","translation":"(the) most wicked of them"}],"13":[{"position":1,"arabic":"فَقَالَ","translation":"But said"},{"position":2,"arabic":"لَهُمْ","translation":"to them"},{"position":3,"arabic":"رَسُولُ","translation":"(the) Messenger"},{"position":4,"arabic":"ٱللَّهِ","translation":"(of) Allah"},{"position":5,"arabic":"نَاقَةَ","translation":"(It is the) she-camel"},{"position":6,"arabic":"ٱللَّهِ","translation":"(of) Allah"},{"position":7,"arabic":"وَسُقْيَـٰهَا","translation":"and her drink"}],"14":[{"position":1,"arabic":"فَكَذَّبُوهُ","translation":"But they denied him"},{"position":2,"arabic":"فَعَقَرُوهَا","translation":"and they hamstrung her"},{"position":3,"arabic":"فَدَمْدَمَ","translation":"So destroyed"},{"position":4,"arabic":"عَلَيْهِمْ","translation":"them"},{"position":5,"arabic":"رَبُّهُم","translation":"their Lord"},{"position":6,"arabic":"بِذَنۢبِهِمْ","translation":"for their sin"},{"position":7,"arabic":"فَسَوَّىٰهَا","translation":"and leveled them"}],"15":[{"position":1,"arabic":"وَلَا","translation":"And not"},{"position":2,"arabic":"يَخَافُ","translation":"He fears"},{"position":3,"arabic":"عُقْبَـٰهَا","translation":"its consequences"}]}