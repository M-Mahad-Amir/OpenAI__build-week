{"1":[{"position":1,"arabic":"قُلْ","translation":"Say"},{"position":2,"arabic":"يَـٰٓأَيُّهَا","translation":"O"},{"position":3,"arabic":"ٱلْكَـٰفِرُونَ","translation":"disbelievers"}],"2":[{"position":1,"arabic":"لَآ","translation":"Not"},{"position":2,"arabic":"أَعْبُدُ","translation":"I worship"},{"position":3,"arabic":"مَا","translation":"what"},{"position":4,"arabic":"تَعْبُدُونَ","translation":"you worship"}],"3":[{"position":1,"arabic":"وَلَآ","translation":"And not"},{"position":2,"arabic":"أَنتُمْ","translation":"you"},{"position":3,"arabic":"عَـٰبِدُونَ","translation":"(are) worshippers"},{"position":4,"arabic":"مَآ","translation":"(of) what"},{"position":5,"arabic":"أَعْبُدُ","translation":"I worship"}],"4":[{"position":1,"arabic":"وَلَآ","translation":"And not"},{"position":2,"arabic":"أَنَا۠","translation":"I am"},{"position":3,"arabic":"عَابِدٌۭ","translation":"a worshipper"},{"position":4,"arabic":"مَّا","translation":"(of) what"},{"position":5,"arabic":"عَبَدتُّمْ","translation":"you worship"}],"5":[{"position":1,"arabic":"وَلَآ","translation":"And not"},{"position":2,"arabic":"أَنتُمْ","translation":"you"},{"position":3,"arabic":"عَـٰبِدُونَ","translation":"(are) worshippers"},{"position":4,"arabic":"مَآ","translation":"(of) what"},{"position":5,"arabic":"أَعْبُدُ","translation":"I worship"}],"6":[{"position":1,"arabic":"لَكُمْ","translation":"For you"},{"position":2,"arabic":"دِينُكُمْ","translation":"(is) your religion"},{"position":3,"arabic":"وَلِىَ","translation":"and for me"},{"position":4,"arabic":"دِينِ","translation":"(is) my religion"}]}