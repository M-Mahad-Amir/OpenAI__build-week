{"1":[{"position":1,"arabic":"أَرَءَيْتَ","translation":"Have you seen"},{"position":2,"arabic":"ٱلَّذِى","translation":"the one who"},{"position":3,"arabic":"يُكَذِّبُ","translation":"denies"},{"position":4,"arabic":"بِٱلدِّينِ","translation":"the Judgment"}],"2":[{"position":1,"arabic":"فَذَٰلِكَ","translation":"Then that"},{"position":2,"arabic":"ٱلَّذِى","translation":"(is) the one who"},{"position":3,"arabic":"يَدُعُّ","translation":"repulses"},{"position":4,"arabic":"ٱلْيَتِيمَ","translation":"the orphan"}],"3":[{"position":1,"arabic":"وَلَا","translation":"And (does) not"},{"position":2,"arabic":"يَحُضُّ","translation":"feel the urge"},{"position":3,"arabic":"عَلَىٰ","translation":"to"},{"position":4,"arabic":"طَعَامِ","translation":"feed"},{"position":5,"arabic":"ٱلْمِسْكِينِ","translation":"the poor"}],"4":[{"position":1,"arabic":"فَوَيْلٌۭ","translation":"So woe"},{"position":2,"arabic":"لِّلْمُصَلِّينَ","translation":"to those who pray"}],"5":[{"position":1,"arabic":"ٱلَّذِينَ","translation":"Those who"},{"position":2,"arabic":"هُمْ","translation":"[they]"},{"position":3,"arabic":"عَن","translation":"about"},{"position":4,"arabic":"صَلَاتِهِمْ","translation":"their prayers"},{"position":5,"arabic":"سَاهُونَ","translation":"(are) neglectful"}],"6":[{"position":1,"arabic":"ٱلَّذِينَ","translation":"Those who"},{"position":2,"arabic":"هُمْ","translation":"[they]"},{"position":3,"arabic":"يُرَآءُونَ","translation":"make show"}],"7":[{"position":1,"arabic":"وَيَمْنَعُونَ","translation":"And they deny"},{"position":2,"arabic":"ٱلْمَاعُونَ","translation":"[the] small kindnesses"}]}