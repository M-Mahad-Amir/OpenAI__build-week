{"1":[{"position":1,"arabic":"وَٱلضُّحَىٰ","translation":"By the morning brightness"}],"2":[{"position":1,"arabic":"وَٱلَّيْلِ","translation":"And the night"},{"position":2,"arabic":"إِذَا","translation":"when"},{"position":3,"arabic":"سَجَىٰ","translation":"it covers with darkness"}],"3":[{"position":1,"arabic":"مَا","translation":"Not"},{"position":2,"arabic":"وَدَّعَكَ","translation":"has forsaken you"},{"position":3,"arabic":"رَبُّكَ","translation":"your Lord"},{"position":4,"arabic":"وَمَا","translation":"and not"},{"position":5,"arabic":"قَلَىٰ","translation":"He is displeased"}],"4":[{"position":1,"arabic":"وَلَلْـَٔاخِرَةُ","translation":"And surely the Hereafter"},{"position":2,"arabic":"خَيْرٌۭ","translation":"(is) better"},{"position":3,"arabic":"لَّكَ","translation":"for you"},{"position":4,"arabic":"مِنَ","translation":"than"},{"position":5,"arabic":"ٱلْأُولَىٰ","translation":"the first"}],"5":[{"position":1,"arabic":"وَلَسَوْفَ","translation":"And soon"},{"position":2,"arabic":"يُعْطِيكَ","translation":"will give you"},{"position":3,"arabic":"رَبُّكَ","translation":"your Lord"},{"position":4,"arabic":"فَتَرْضَىٰٓ","translation":"then you will be satisfied"}],"6":[{"position":1,"arabic":"أَلَمْ","translation":"Did not"},{"position":2,"arabic":"يَجِدْكَ","translation":"He find you"},{"position":3,"arabic":"يَتِيمًۭا","translation":"an orphan"},{"position":4,"arabic":"فَـَٔاوَىٰ","translation":"and give shelter"}],"7":[{"position":1,"arabic":"وَوَجَدَكَ","translation":"And He found you"},{"position":2,"arabic":"ضَآلًّۭا","translation":"lost"},{"position":3,"arabic":"فَهَدَىٰ","translation":"so He guided"}],"8":[{"position":1,"arabic":"وَوَجَدَكَ","translation":"And He found you"},{"position":2,"arabic":"عَآئِلًۭا","translation":"in need"},{"position":3,"arabic":"فَأَغْنَىٰ","translation":"so He made self-sufficient"}],"9":[{"position":1,"arabic":"فَأَمَّا","translation":"So as for"},{"position":2,"arabic":"ٱلْيَتِيمَ","translation":"the orphan"},{"posit