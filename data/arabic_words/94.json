{"1":[{"position":1,"arabic":"أَلَمْ","translation":"Have not"},{"position":2,"arabic":"نَشْرَحْ","translation":"We expanded"},{"position":3,"arabic":"لَكَ","translation":"for you"},{"position":4,"arabic":"صَدْرَكَ","translation":"your breast"}],"2":[{"position":1,"arabic":"وَوَضَعْنَا","translation":"And We removed"},{"position":2,"arabic":"عَنكَ","translation":"from you"},{"position":3,"arabic":"وِزْرَكَ","translation":"your burden"}],"3":[{"position":1,"arabic":"ٱلَّذِىٓ","translation":"Which"},{"position":2,"arabic":"أَنقَضَ","translation":"weighed upon"},{"position":3,"arabic":"ظَهْرَكَ","translation":"your back"}],"4":[{"position":1,"arabic":"وَرَفَعْنَا","translation":"And We raised high"},{"position":2,"arabic":"لَكَ","translation":"for you"},{"position":3,"arabic":"ذِكْرَكَ","translation":"your reputation"}],"5":[{"position":1,"arabic":"فَإِنَّ","translation":"So indeed"},{"position":2,"arabic":"مَعَ","translation":"with"},{"position":3,"arabic":"ٱلْعُسْرِ","translation":"the hardship"},{"position":4,"arabic":"يُسْرًا","translation":"(is) ease"}],"6":[{"position":1,"arabic":"إِنَّ","translation":"Indeed"},{"position":2,"arabic":"مَعَ","translation":"with"},{"position":3,"arabic":"ٱلْعُسْرِ","translation":"the hardship"},{"position":4,"arabic":"يُسْرًۭا","translation":"(is) ease"}],"7":[{"position":1,"arabic":"فَإِذَا","translation":"So when"},{"position":2,"arabic":"فَرَغْتَ","translation":"you have finished"},{"position":3,"arabic":"فَٱنصَبْ","translation":"then labor hard"}],"8":[{"position":1,"arabic":"وَإِلَىٰ","translation":"And to"},{"position":2,"arabic":"رَبِّكَ","translation":"your Lord"},{"position":3,"arabic":"فَٱرْغَب","translation":"turn your attention"}]}