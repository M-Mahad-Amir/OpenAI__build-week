{"1":[{"position":1,"arabic":"أَلَمْ","translation":"Have not"},{"position":2,"arabic":"تَرَ","translation":"you seen"},{"position":3,"arabic":"كَيْفَ","translation":"how"},{"position":4,"arabic":"فَعَلَ","translation":"dealt"},{"position":5,"arabic":"رَبُّكَ","translation":"your Lord"},{"position":6,"arabic":"بِأَصْحَـٰبِ","translation":"with (the) Companions"},{"position":7,"arabic":"ٱلْفِيلِ","translation":"(of the) Elephant"}],"2":[{"position":1,"arabic":"أَلَمْ","translation":"Did not"},{"position":2,"arabic":"يَجْعَلْ","translation":"He make"},{"position":3,"arabic":"كَيْدَهُمْ","translation":"their plan"},{"position":4,"arabic":"فِى","translation":"go"},{"position":5,"arabic":"تَضْلِيلٍۢ","translation":"astray"}],"3":[{"position":1,"arabic":"وَأَرْسَلَ","translation":"And He sent"},{"position":2,"arabic":"عَلَيْهِمْ","translation":"against them"},{"position":3,"arabic":"طَيْرًا","translation":"birds"},{"position":4,"arabic":"أَبَابِيلَ","translation":"(in) flocks"}],"4":[{"position":1,"arabic":"تَرْمِيهِم","translation":"Striking them"},{"position":2,"arabic":"بِحِجَارَةٍۢ","translation":"with stones"},{"position":3,"arabic":"مِّن","translation":"of"},{"position":4,"arabic":"سِجِّيلٍۢ","translation":"baked clay"}],"5":[{"position":1,"arabic":"فَجَعَلَهُمْ","translation":"Then He made them"},{"position":2,"arabic":"كَعَصْفٍۢ","translation":"like straw"},{"position":3,"arabic":"مَّأْكُولٍۭ","translation":"eaten up"}]}