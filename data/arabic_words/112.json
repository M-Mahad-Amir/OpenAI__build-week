{"1":[{"position":1,"arabic":"قُلْ","translation":"Say"},{"position":2,"arabic":"هُوَ","translation":"He"},{"position":3,"arabic":"ٱللَّهُ","translation":"(is) Allah"},{"position":4,"arabic":"أَحَدٌ","translation":"the One"}],"2":[{"position":1,"arabic":"ٱللَّهُ","translation":"Allah"},{"position":2,"arabic":"ٱلصَّمَدُ","translation":"the Eternal, the Absolute"}],"3":[{"position":1,"arabic":"لَمْ","translation":"Not"},{"position":2,"arabic":"يَلِدْ","translation":"He begets"},{"position":3,"arabic":"وَلَمْ","translation":"and not"},{"position":4,"arabic":"يُولَدْ","translation":"He is begotten"}],"4":[{"position":1,"arabic":"وَلَمْ","translation":"And not"},{"position":2,"arabic":"يَكُن","translation":"is"},{"position":3,"arabic":"لَّهُۥ","translation":"for Him"},{"position":4,"arabic":"كُفُوًا","translation":"equivalent"},{"position":5,"arabic":"أَحَدٌۢ","translation":"any [one]"}]}